<?xml version="1.0" encoding="utf-8"?>
<!--
  Намеренно небезопасная Network Security Config.

  Слабость №1 (base-config): доверие к сертификатам, установленным
  пользователем (<certificates src="user"/>). Это позволяет любому,
  кто уговорил пользователя поставить «корпоративный» CA, читать весь
  TLS-трафик приложения через прозрачный прокси.

  Слабость №2 (base-config): cleartextTrafficPermitted="true" —
  глобально разрешает HTTP-трафик ко ВСЕМ доменам.

  Слабость №3 (domain-config): дополнительно явно разрешает HTTP
  для api.legacy.example.com и его поддоменов.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">api.legacy.example.com</domain>
    </domain-config>
</network-security-config>
